PORT=5000
NODE_ENV=development

# Database Configuration (MySQL Laragon)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=portfolio_db

# Email Configuration (Gmail/Other SMTP)
